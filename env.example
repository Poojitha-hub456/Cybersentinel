# CyberSentinel Configuration
# ===========================
# Copy this file to: config/.env
# Replace the placeholder values with your actual API keys
# Never commit config/.env to git (it's in .gitignore)

# ── AlienVault OTX ──────────────────────────────────────────────────────────
# Get free API key from: https://otx.alienvault.com/settings/api
# Sign up (free) → Settings → API → Copy your API Key
OTX_API_KEY=your_otx_api_key_here

# ── OpenAI API (for Claude wrapper) ─────────────────────────────────────────
# Get free tier API key from: https://platform.openai.com/api-keys
# (Optional for Phase 3+, not needed for Phase 1)
OPENAI_API_KEY=your_openai_api_key_here

# ── Google Generative AI (Gemini) ───────────────────────────────────────────
# Get free tier API key from: https://ai.google.dev/
# (Optional for Phase 3+, not needed for Phase 1)
GOOGLE_API_KEY=your_google_api_key_here

# ── Anthropic Claude API ────────────────────────────────────────────────────
# Get API key from: https://console.anthropic.com/
# (Optional for Phase 3+, not needed for Phase 1)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Local LLM (optional) ────────────────────────────────────────────────────
# If using Ollama or local models
# LOCAL_LLM_URL=http://localhost:11434
# LOCAL_LLM_MODEL=llama2

# ── Data Settings ───────────────────────────────────────────────────────────
# Number of days back for CVE fetching
NVD_DAYS_BACK=7
# Number of OTX pulses to fetch
OTX_LIMIT=30

# ── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
